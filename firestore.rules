rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'super_admin' || 
        (request.auth.token.email == "johnkimeujk6@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isSchoolAdmin(schoolId) {
      return isAuthenticated() && getUserData().role == 'school_admin' && getUserData().schoolId == schoolId;
    }
    
    function belongsToSchool(schoolId) {
      return isAuthenticated() && getUserData().schoolId == schoolId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
      allow update: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin') || request.auth.uid == userId;
      allow delete: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /grades/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /streams/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /subjects/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /exams/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /timetable/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /elearning/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /library/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /messages/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
    
    match /fees/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserData().role == 'school_admin');
    }
  }
}
