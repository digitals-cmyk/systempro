rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data : null;
    }
    
    function isSuperAdmin() {
      let userData = getUserData();
      return isAuthenticated() && (
        (userData != null && userData.role == 'super_admin') || 
        (request.auth.token.email == 'johnkimeujk6@gmail.com' && request.auth.token.email_verified == true)
      );
    }
    
    function isSchoolAdmin(schoolId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == 'school_admin' && userData.schoolId == schoolId;
    }
    
    function isTeacher(schoolId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == 'teacher' && userData.schoolId == schoolId;
    }
    
    function isStaff(schoolId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == 'staff' && userData.schoolId == schoolId;
    }
    
    function isStudentOrParent(schoolId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && (userData.role == 'student' || userData.role == 'parent') && userData.schoolId == schoolId;
    }
    
    function belongsToSchool(schoolId) {
      return isSchoolAdmin(schoolId) || isTeacher(schoolId) || isStaff(schoolId) || isStudentOrParent(schoolId);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isSuperAdmin() || (getUserData() != null && getUserData().schoolId == resource.data.schoolId && getUserData().role in ['school_admin', 'teacher']));
      allow create: if isAuthenticated() && hasRequiredFields(['role', 'fullName', 'status', 'createdAt']) && (
        isSuperAdmin() || 
        (isSchoolAdmin(request.resource.data.schoolId) && request.resource.data.role != 'super_admin') ||
        isOwner(userId)
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (isSchoolAdmin(resource.data.schoolId) && request.resource.data.role != 'super_admin') ||
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.schoolId == resource.data.schoolId)
      );
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /schools/{schoolId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(schoolId));
      allow create: if isSuperAdmin() && hasRequiredFields(['name', 'code', 'status', 'createdAt']);
      allow update: if isSuperAdmin() || isSchoolAdmin(schoolId);
      allow delete: if isSuperAdmin();
    }
    
    match /learners/{learnerId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow create: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /exams/{examId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow create: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isTeacher(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId);
    }
    
    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /streams/{streamId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /subjectAllocations/{allocationId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /gradeSystems/{systemId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId);
    }
    
    match /timetable/{timetableId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isTeacher(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId);
    }
    
    match /elearning/{materialId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isTeacher(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId);
    }
    
    match /library/{bookId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isTeacher(request.resource.data.schoolId) || isStaff(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId) || isStaff(resource.data.schoolId);
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isTeacher(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId);
    }
    
    match /fees/{feeId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToSchool(resource.data.schoolId));
      allow write: if isSuperAdmin() || isSchoolAdmin(request.resource.data.schoolId) || isStaff(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isSchoolAdmin(resource.data.schoolId) || isStaff(resource.data.schoolId);
    }
  }
}
