{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (super_admin, school_admin, teacher, student, parent)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_admin", "teacher", "student", "parent", "staff"] },
        "schoolId": { "type": "string", "description": "ID of the school this user belongs to (null for super_admin)" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "fullName", "status", "createdAt"]
    },
    "School": {
      "title": "School",
      "description": "A school registered in the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "principalName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code", "status", "createdAt"]
    },
    "Learner": {
      "title": "Learner",
      "description": "A student enrolled in a school",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "dob": { "type": "string" },
        "dateOfAdmission": { "type": "string" },
        "assessmentNumber": { "type": "string" },
        "grade": { "type": "string" },
        "stream": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "admissionNumber", "fullName", "createdAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An examination",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "term": { "type": "string" },
        "year": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "ongoing", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "name", "term", "year", "status", "createdAt"]
    },
    "Grade": {
      "title": "Grade",
      "description": "A class grade level",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["schoolId", "name"]
    },
    "Stream": {
      "title": "Stream",
      "description": "A class stream",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["schoolId", "name"]
    },
    "Subject": {
      "title": "Subject",
      "description": "An academic subject",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["schoolId", "name", "code"]
    },
    "SubjectAllocation": {
      "title": "Subject Allocation",
      "description": "Allocation of a subject to a teacher and grade",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "subjectId": { "type": "string" },
        "gradeId": { "type": "string" },
        "teacherId": { "type": "string" }
      },
      "required": ["schoolId", "subjectId", "gradeId", "teacherId"]
    },
    "GradeSystem": {
      "title": "Grade System",
      "description": "Grading scale",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "minMark": { "type": "number" },
        "maxMark": { "type": "number" },
        "gradeLetter": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["schoolId", "name", "minMark", "maxMark", "gradeLetter"]
    },
    "Timetable": {
      "title": "Timetable",
      "description": "Class schedule",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "day": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["schoolId", "grade", "subject", "day", "time"]
    },
    "Material": {
      "title": "Material",
      "description": "E-learning material",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "title", "type", "url", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "Library book",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "borrowed", "lost"] }
      },
      "required": ["schoolId", "title", "author", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Communication message",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "recipientGroup": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "recipientGroup", "content", "createdAt"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Fee record",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "learnerId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolId", "learnerId", "totalAmount", "paidAmount", "balance", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": { "$ref": "#/entities/User" }, "description": "Users collection" },
    "schools/{schoolId}": { "schema": { "$ref": "#/entities/School" }, "description": "Schools collection" },
    "learners/{learnerId}": { "schema": { "$ref": "#/entities/Learner" }, "description": "Learners collection" },
    "exams/{examId}": { "schema": { "$ref": "#/entities/Exam" }, "description": "Exams collection" },
    "grades/{gradeId}": { "schema": { "$ref": "#/entities/Grade" }, "description": "Grades collection" },
    "streams/{streamId}": { "schema": { "$ref": "#/entities/Stream" }, "description": "Streams collection" },
    "subjects/{subjectId}": { "schema": { "$ref": "#/entities/Subject" }, "description": "Subjects collection" },
    "subject_allocations/{allocationId}": { "schema": { "$ref": "#/entities/SubjectAllocation" }, "description": "Subject allocations collection" },
    "grade_systems/{systemId}": { "schema": { "$ref": "#/entities/GradeSystem" }, "description": "Grade systems collection" },
    "timetables/{timetableId}": { "schema": { "$ref": "#/entities/Timetable" }, "description": "Timetables collection" },
    "materials/{materialId}": { "schema": { "$ref": "#/entities/Material" }, "description": "E-learning materials collection" },
    "books/{bookId}": { "schema": { "$ref": "#/entities/Book" }, "description": "Library books collection" },
    "messages/{messageId}": { "schema": { "$ref": "#/entities/Message" }, "description": "Messages collection" },
    "fees/{feeId}": { "schema": { "$ref": "#/entities/Fee" }, "description": "Fees collection" }
  }
}
